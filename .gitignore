!/ai_models/driver_behavior/best.pt
!/ai_models/passenger_counting/models/baseline/weights/best.pt

# Output files
*.avi
*.mp4

# Python cache
__pycache__/
*.pyc

# Environment
venv/
.venv/
.venv*/
.env
*.env
.env.*
*.local.env
